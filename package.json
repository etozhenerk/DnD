{
  "name": "dnd-campaign-atlas",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "build:pages": "npm run typecheck && vite build --mode github-pages",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
